# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright/.clerk
/tests/e2e/.auth
/test-results

# next.js
/.next/
/out/

# production
/build
/public/vendor/

# misc
.DS_Store
*.pem
/.tmp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite
*.sqlite
*.sqlite-shm
*.sqlite-wal
