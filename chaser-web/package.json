{
  "name": "chaser-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun scripts/syncRubyWasmAsset.ts && bun --bun concurrently \"bun run server/wsServer.ts\" \"bun --bun next dev\"",
    "build": "bun --bun scripts/syncRubyWasmAsset.ts && bun --bun next build",
    "start": "bun --bun next start",
    "ruby-wasm:sync": "bun --bun scripts/syncRubyWasmAsset.ts",
    "db:reset": "bun --bun scripts/dbReset.ts",
    "db:seed": "bun --bun scripts/dbSeed.ts",
    "test": "bun test",
    "test:e2e": "env PATH=\"/usr/bin:/usr/local/bin:$PATH\" PLAYWRIGHT_TEST_BASE_DIR=. playwright test",
    "lint": "bun --bun biome check",
    "format": "bun --bun biome format --write",
    "typecheck": "bun tsgo --noEmit"
  },
  "dependencies": {
    "@clerk/localizations": "^3.32.1",
    "@clerk/nextjs": "^6.36.5",
    "@headlessui/react": "^2.2.9",
    "@kuband/react-blockly": "^10.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@ruby/3.4-wasm-wasi": "^2.7.2",
    "blockly": "^12.3.1",
    "console-feed": "^3.8.0",
    "konva": "^10.0.12",
    "kysely": "^0.28.9",
    "kysely-bun-worker": "^1.2.1",
    "monaco-editor": "^0.55.1",
    "next": "16.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-konva": "^19.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@clerk/testing": "^1.13.26",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.19.27",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20251222.1",
    "bun-types": "^1.3.5",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
